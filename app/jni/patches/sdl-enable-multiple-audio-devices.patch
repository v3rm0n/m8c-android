+#else
+    // Allow apps to override the OUTPUT device ID via hint even when multi-device
+    // enumeration is disabled, to route audio to a specific Android device.
+    // Only applies to output streams; input (M8 capture) always uses its own device.
+    if (!recording) {
+        const char *hint = SDL_GetHint("SDL_ANDROID_AUDIO_DEVICE_ID");
